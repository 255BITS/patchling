{
  "name": "patchling",
  "version": "0.2.1",
  "description": "Natural-language code transformation as a browser-first JS primitive: generateDiff turns a plain-English goal into a git diff, and smartapply melds it into your source even when git apply would reject it. Wired to NanoGPT. Formerly gptdiff-js.",
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./oauth": {
      "types": "./src/oauth.d.ts",
      "default": "./src/oauth.js"
    },
    "./llm": {
      "types": "./src/llm.d.ts",
      "default": "./src/llm.js"
    }
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/255BITS/patchling.git"
  },
  "homepage": "https://github.com/255BITS/patchling#readme",
  "bugs": {
    "url": "https://github.com/255BITS/patchling/issues"
  },
  "scripts": {
    "prepublishOnly": "npm test",
    "test": "node --test",
    "test:live": "GPTDIFF_LIVE=1 node --test test/live.test.js",
    "benchmark": "node benchmark/run.js",
    "types": "rm -f src/*.d.ts && tsc -p tsconfig.json"
  },
  "keywords": [
    "patchling",
    "smartapply",
    "diff",
    "patch",
    "llm",
    "code-transformation",
    "nanogpt",
    "git",
    "browser",
    "gptdiff"
  ],
  "author": "255labs",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3"
  }
}
