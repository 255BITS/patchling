{
  "name": "gptdiff-js",
  "version": "0.2.0",
  "description": "Generate and apply git diffs using LLMs — a browser-first JavaScript port of gptdiff (generateDiff + smartapply), wired to NanoGPT.",
  "type": "module",
  "main": "src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./oauth": {
      "types": "./src/oauth.d.ts",
      "default": "./src/oauth.js"
    },
    "./llm": {
      "types": "./src/llm.d.ts",
      "default": "./src/llm.js"
    }
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/255BITS/gptdiff-js.git"
  },
  "homepage": "https://github.com/255BITS/gptdiff-js#readme",
  "bugs": {
    "url": "https://github.com/255BITS/gptdiff-js/issues"
  },
  "scripts": {
    "prepublishOnly": "npm test",
    "test": "node --test",
    "test:live": "GPTDIFF_LIVE=1 node --test test/live.test.js",
    "benchmark": "node benchmark/run.js",
    "types": "rm -f src/*.d.ts && tsc -p tsconfig.json"
  },
  "keywords": [
    "gptdiff",
    "diff",
    "llm",
    "nanogpt",
    "git",
    "smartapply",
    "browser"
  ],
  "author": "255labs",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3"
  }
}
